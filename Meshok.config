<?xml version="1.0" encoding="utf-8"?>
<VSHelperZip>
  <Root>.</Root>
  <OutputDir>_zip</OutputDir>
  <ArchiveName>{Solution.Name}.zip</ArchiveName>
  <StartProject>GH.Components\GH.Components.csproj</StartProject>
  <IncludeProjectClosure>true</IncludeProjectClosure>
  <IncludeSolutionFiles>true</IncludeSolutionFiles>
  <IncludeManifest>true</IncludeManifest>
  <Include>
    <File>Meshok.Sln</File>
    <File>Meshok.config</File>
    <File>README.md</File>
    <File>LICENSE*</File>
    <File>Directory.Build.*</File>
    <File>Directory.Packages.props</File>
    <File>global.json</File>
    <File>NuGet.config</File>
    <File>.editorconfig</File>
    <File>.gitattributes</File>
    <File>.gitignore</File>
    <File>GH.Components</File>
    <File>MehokBrowser</File>
    <File>NewsMaker</File>
  </Include>
  <Exclude>
    <Pattern>bin/**</Pattern>
    <Pattern>**/bin/**</Pattern>
    <Pattern>obj/**</Pattern>
    <Pattern>**/obj/**</Pattern>
    <Pattern>.vs/**</Pattern>
    <Pattern>**/.vs/**</Pattern>
    <Pattern>.git/**</Pattern>
    <Pattern>**/.git/**</Pattern>
    <Pattern>.idea/**</Pattern>
    <Pattern>**/.idea/**</Pattern>
    <Pattern>.vscode/**</Pattern>
    <Pattern>**/.vscode/**</Pattern>
    <Pattern>packages/**</Pattern>
    <Pattern>**/packages/**</Pattern>
    <Pattern>TestResults/**</Pattern>
    <Pattern>**/TestResults/**</Pattern>
    <Pattern>_zip/**</Pattern>
    <Pattern>**/_zip/**</Pattern>
    <Pattern>VSIX/**</Pattern>
    <Pattern>**/VSIX/**</Pattern>
    <Pattern>*.user</Pattern>
    <Pattern>*.suo</Pattern>
    <Pattern>*.cache</Pattern>
    <Pattern>*.log</Pattern>
    <Pattern>*.zip</Pattern>
    <Pattern>*.nupkg</Pattern>
    <Pattern>*.vsix</Pattern>
    <Pattern>*.pdb</Pattern>
  </Exclude>
</VSHelperZip>