@page
@model IndexModel
@{
    ViewData["Title"] = "Обзор";
}

<section class="hero">
    <div class="hero-copy">
        <span class="eyebrow">NewsMaker становится веб-сервисом</span>
        <h1>Новости приходят волнами.<br />Управляйте каждой.</h1>
        <p>
            NewsWave переносит подготовку и рассылку новостей в браузер:
            адресаты, шаблоны, очередь и история теперь собраны в одном месте.
        </p>
        <a asp-page="/Mail/Index" class="hero-action">Создать рассылку <span>→</span></a>
    </div>
    <div class="wave-orbit" aria-hidden="true">
        <div class="orbit orbit-one"></div>
        <div class="orbit orbit-two"></div>
        <div class="orbit-core">NW</div>
    </div>
</section>

<section class="metric-grid">
    <article class="metric-card">
        <span>SMTP</span>
        <strong>@(Model.MailConfigured ? "готов" : "настройте")</strong>
        <small>@(Model.MailConfigured ? "Канал отправки подключён" : "Нужны сервер и адрес отправителя")</small>
    </article>
    <article class="metric-card">
        <span>Активные адресаты</span>
        <strong>@Model.ContactCount</strong>
        <small><a asp-page="/Contacts/Index">Открыть адресную книгу</a></small>
    </article>
    <article class="metric-card">
        <span>Шаблоны</span>
        <strong>@Model.TemplateCount</strong>
        <small><a asp-page="/Templates/Index">Открыть библиотеку</a></small>
    </article>
    <article class="metric-card">
        <span>В работе</span>
        <strong>@Model.ActiveCount</strong>
        <small>текущая очередь</small>
    </article>
    <article class="metric-card">
        <span>Завершено</span>
        <strong>@Model.SentCount</strong>
        <small>успешных рассылок</small>
    </article>
    <article class="metric-card">
        <span>Требуют внимания</span>
        <strong>@Model.FailedCount</strong>
        <small>ошибок отправки</small>
    </article>
</section>

<section class="panel roadmap-panel">
    <div class="panel-title">
        <div><span class="step-number">Маршрут</span><h2>Развитие NewsWave</h2></div>
    </div>
    <div class="roadmap">
        <div class="roadmap-item complete">
            <span>01</span>
            <div><strong>Почтовое отделение</strong><small>SMTP, очередь, постоянная история</small></div>
        </div>
        <div class="roadmap-item complete">
            <span>02</span>
            <div><strong>Адресная книга</strong><small>получатели и группы</small></div>
        </div>
        <div class="roadmap-item complete">
            <span>03</span>
            <div><strong>Шаблоны</strong><small>повторное использование писем</small></div>
        </div>
        <div class="roadmap-item">
            <span>04</span>
            <div><strong>Лента новостей</strong><small>перенос подготовки контента из NewsMaker</small></div>
        </div>
    </div>
</section>
