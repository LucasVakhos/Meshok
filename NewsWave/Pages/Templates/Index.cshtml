@page
@model NewsWave.Pages.Templates.IndexModel
@using System.Text.Json
@{
    ViewData["Title"] = "Шаблоны";
    string editorTitle = Model.IsEditing ? "Редактирование шаблона" : "Новый шаблон";
    string saveText = Model.IsEditing ? "Сохранить изменения" : "Сохранить";
    string templatesJson = JsonSerializer.Serialize(Model.Templates);
    string nameJson = JsonSerializer.Serialize(Model.Input.Name);
    string subjectJson = JsonSerializer.Serialize(Model.Input.Subject);
    string bodyJson = JsonSerializer.Serialize(Model.Input.Body);
}

<div class="page-heading">
    <div>
        <span class="eyebrow">Библиотека писем</span>
        <h1>Шаблоны</h1>
        <p>Сохраняйте удачные письма и запускайте новую волну без копирования.</p>
    </div>
</div>

@if (TempData["TemplateSuccess"] is string success)
{
    <div class="alert alert-success">@success</div>
}
<div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

<div class="directory-grid template-layout">
    <section class="panel">
        <div class="panel-title">
            <div><span class="step-number">01</span><h2>@editorTitle</h2></div>
            @if (Model.IsEditing)
            {
                <a asp-page="/Templates/Index" class="btn btn-sm btn-outline-secondary">Отмена</a>
            }
        </div>
        <form method="post" asp-page-handler="Save" id="templateForm">
            <input asp-for="EditId" type="hidden" />
            <input asp-for="Input.Name" class="form-control native-editor" />
            <input asp-for="Input.Subject" class="form-control native-editor" />
            <textarea asp-for="Input.Body" class="form-control native-editor" rows="10"></textarea>
            <label class="form-check native-editor"><input asp-for="Input.IsHtml" class="form-check-input" /> HTML-шаблон</label>

            <div class="mb-3">
                <label class="form-label">Название</label>
                <div id="templateName" class="dx-host"></div>
                <span asp-validation-for="Input.Name" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Тема</label>
                <div id="templateSubject" class="dx-host"></div>
                <span asp-validation-for="Input.Subject" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label class="form-label">Текст</label>
                <div id="templateBody" class="dx-host"></div>
                <span asp-validation-for="Input.Body" class="text-danger"></span>
            </div>
            <div class="d-flex align-items-center justify-content-between gap-3">
                <div id="templateHtml" class="dx-host"></div>
                <button type="submit" class="btn btn-wave native-editor">@saveText</button>
                <div id="addTemplateButton" class="dx-host"></div>
            </div>
        </form>
    </section>

    <section class="panel directory-panel">
        <div class="panel-title">
            <div><span class="step-number">02</span><h2>Сохранённые шаблоны</h2></div>
            <span class="muted">@Model.Templates.Count шаблонов</span>
        </div>
        <div class="native-grid">
    <table class="table">
        <thead><tr><th>Название</th><th>Тема</th><th></th></tr></thead>
        <tbody>
        @foreach (var template in Model.Templates)
        {
            <tr>
                <td><a asp-page="/Mail/Index" asp-route-templateId="@template.Id">@template.Name</a></td><td>@template.Subject</td>
                <td>
                    <div class="d-flex gap-2">
                        <a asp-page="/Templates/Index" asp-route-editId="@template.Id" class="btn btn-sm btn-outline-secondary">Изменить</a>
                        <form method="post" asp-page-handler="Delete">
                            <button class="btn btn-sm btn-outline-danger" name="deleteId" value="@template.Id">Удалить</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>
<div id="templatesGrid" class="dx-host"></div>
    </section>
</div>

<form method="post" asp-page-handler="Delete" id="deleteTemplateForm">
    <input type="hidden" name="deleteId" id="deleteTemplateId" />
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        window.NewsWave.enhancePage(() => {
        const templates = @Html.Raw(templatesJson);
        const syncTemplate = (selector, value) => $(selector).val(value ?? "");

        $("#templateName").dxTextBox({
            value: @Html.Raw(nameJson),
            placeholder: "Например, еженедельный дайджест",
            onValueChanged: e => syncTemplate("#Input_Name", e.value)
        });
        $("#templateSubject").dxTextBox({
            value: @Html.Raw(subjectJson),
            placeholder: "Тема письма",
            onValueChanged: e => syncTemplate("#Input_Subject", e.value)
        });
        $("#templateBody").dxTextArea({
            value: @Html.Raw(bodyJson),
            minHeight: 220,
            autoResizeEnabled: true,
            placeholder: "Текст шаблона",
            onValueChanged: e => syncTemplate("#Input_Body", e.value)
        });
        $("#templateHtml").dxCheckBox({
            value: @Model.Input.IsHtml.ToString().ToLowerInvariant(),
            text: "HTML-шаблон",
            onValueChanged: e => $("#Input_IsHtml").prop("checked", e.value)
        });
        $("#addTemplateButton").dxButton({
            text: @Html.Raw(JsonSerializer.Serialize(saveText)),
            icon: "save",
            type: "default",
            onClick: () => document.getElementById("templateForm").requestSubmit()
        });

        $("#templatesGrid").dxDataGrid({
            dataSource: templates,
            keyExpr: "Id",
            showBorders: false,
            rowAlternationEnabled: true,
            noDataText: "Шаблонов пока нет.",
            searchPanel: { visible: true, placeholder: "Найти шаблон…" },
            paging: { pageSize: 12 },
            columns: [
                { dataField: "Name", caption: "Название", minWidth: 180 },
                { dataField: "Subject", caption: "Тема", minWidth: 230 },
                { dataField: "IsHtml", caption: "HTML", dataType: "boolean", width: 75 },
                {
                    type: "buttons",
                    width: 150,
                    buttons: [
                        {
                            icon: "edit",
                            hint: "Изменить",
                            onClick: e => window.location.href = `/Templates?editId=${e.row.data.Id}`
                        },
                        {
                            icon: "email",
                            hint: "Создать письмо",
                            onClick: e => window.location.href = `/Mail?templateId=${e.row.data.Id}`
                        },
                        {
                            icon: "trash",
                            hint: "Удалить",
                            onClick: e => {
                                if (!confirm(`Удалить шаблон «${e.row.data.Name}»?`)) return;
                                $("#deleteTemplateId").val(e.row.data.Id);
                                document.getElementById("deleteTemplateForm").requestSubmit();
                            }
                        }
                    ]
                }
            ]
        });
        });
    </script>
}
