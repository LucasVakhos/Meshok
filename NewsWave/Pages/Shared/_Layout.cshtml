<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - NewsWave</title>
    <link rel="icon" type="image/svg+xml" href="~/img/newswave-mark.svg" />
    <meta name="theme-color" content="#17202a" />
    <link rel="stylesheet" href="~/vendor/bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="~/vendor/devextreme/dx.fluent.blue.light.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/NewsWave.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container">
                <a class="navbar-brand wave-brand" asp-page="/Mail/Index" aria-label="NewsWave — bridgenote.com - с миру по нотке"><img src="~/img/newswave-logo.svg" alt="NewsWave" /></a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-expanded="false" aria-label="Открыть навигацию">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item"><a class="nav-link text-dark" asp-page="/Index">Обзор</a></li>
                        <li class="nav-item"><a class="nav-link text-dark" asp-page="/Mail/Index">Почта</a></li>
                        <li class="nav-item"><a class="nav-link text-dark" asp-page="/Contacts/Index">Адресаты</a></li>
                        <li class="nav-item"><a class="nav-link text-dark" asp-page="/Templates/Index">Шаблоны</a></li>
                        <li class="nav-item"><a class="nav-link text-dark" asp-page="/History/Index">История</a></li>
                    </ul>
                    @if (User.Identity?.AuthenticationType == "Cookies")
                    {
                        <form method="post" asp-page="/Login" asp-page-handler="Logout">
                            <button class="btn btn-sm btn-outline-secondary" type="submit">Выйти</button>
                        </form>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div id="clientError" class="container alert alert-warning client-error" hidden></div>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">&copy; 2026 NewsWave · bridgenote.com - с миру по нотке <img class="footer-staff" src="~/img/newswave-staff.svg" alt="ноты на нотном стане" /></div>
    </footer>

    <script src="~/vendor/jquery/jquery.min.js"></script>
    <script src="~/vendor/bootstrap/bootstrap.bundle.min.js"></script>
    <script src="~/vendor/devextreme/dx.all.js"></script>
    <script src="~/vendor/devextreme/dx.messages.ru.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
