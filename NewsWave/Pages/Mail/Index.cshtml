@page
@model NewsWave.Pages.Mail.IndexModel
@using NewsWave.NewsMaker
@{
    ViewData["Title"] = "NewsMaker";
    int percent = Model.Run.Total == 0 ? 0 : (int)Math.Round(Model.Run.Current * 100d / Model.Run.Total);
}
<div class="page-heading">
    <div>
        <span class="eyebrow">Рассылка обновлений Bridgenote.com</span>
        <h1>NewsMaker</h1>
        <p>@Model.Run.Message</p>
    </div>
    <span class="status-pill @(Model.Run.Running ? "status-warning" : "status-ready")">
        @(Model.Run.Running ? "Выполняется" : "Готов")
    </span>
</div>

@if (TempData["MailSuccess"] is string success) { <div class="alert alert-success">@success</div> }
@if (TempData["MailError"] is string error) { <div class="alert alert-danger">@error</div> }
<div asp-validation-summary="All" class="alert alert-danger"></div>

<div id="mainTabs"></div>
<div class="newsmaker-shell">
    <section id="settingsTab" class="panel newsmaker-tab">
        <div class="panel-title"><div><span class="step-number">Установки</span><h2>Настройки</h2></div></div>
        <form method="post" asp-page-handler="Save" id="settingsForm">
            <div class="settings-tabs">
                <details open>
                    <summary>Настройки запуска</summary>
                    <div class="settings-form-grid">
                        <label><span>Автозапуск программы</span><input asp-for="Settings.Program.Autorun" type="checkbox" /></label>
                        <label><span>Сворачивать в трей</span><input asp-for="Settings.Program.RunCollapced" type="checkbox" /></label>
                        <label><span>Run Day</span>
                            <select asp-for="Settings.Program.RunDay">
                                <option value="0">Воскресенье</option><option value="1">Понедельник</option>
                                <option value="2">Вторник</option><option value="3">Среда</option>
                                <option value="4">Четверг</option><option value="5">Пятница</option>
                                <option value="6">Суббота</option><option value="7">Рассылать в ручном режиме</option>
                            </select>
                        </label>
                        <label><span>Run Time</span><input asp-for="Settings.Program.RunTime" type="time" step="1" /></label>
                    </div>
                </details>
                <details>
                    <summary>BridgeNote</summary>
                    <div class="settings-form-grid">
                        <label><span>Server</span><input asp-for="Settings.BridgeNote.Server" /></label>
                        <label><span>Database</span><input asp-for="Settings.BridgeNote.Database" /></label>
                        <label><span>User</span><input asp-for="Settings.BridgeNote.UserID" /></label>
                        <label><span>Password</span><input asp-for="Settings.BridgeNote.Password" type="password" /></label>
                        <label><span>Port</span><input asp-for="Settings.BridgeNote.Port" type="number" /></label>
                        <label><span>Charset</span><input asp-for="Settings.BridgeNote.CharacterSet" /></label>
                        <label><span>Protocol</span><select asp-for="Settings.BridgeNote.ConnectionProtocol"><option>Tcp</option><option>NamedPipe</option><option>UnixSocket</option><option>SharedMemory</option></select></label>
                        <label><span>Use SSL</span><select asp-for="Settings.BridgeNote.SslMode"><option>None</option><option>Preferred</option><option>Required</option><option>VerifyCA</option><option>VerifyFull</option></select></label>
                    </div>
                    <button type="submit" formaction="?handler=TestDatabase" class="btn btn-outline-secondary">Проверить подключение</button>
                </details>
                <details>
                    <summary>Почтовый сервер</summary>
                    <div class="settings-form-grid">
                        <label><span>Smtp</span><input asp-for="Settings.Post.Smtp" /></label>
                        <label><span>Port</span><input asp-for="Settings.Post.Port" type="number" /></label>
                        <label><span>Login</span><input asp-for="Settings.Post.User" /></label>
                        <label><span>Password</span><input asp-for="Settings.Post.PassWrd" type="password" /></label>
                        <label><span>Back Email</span><input asp-for="Settings.Post.BridgeEmail" type="email" /></label>
                        <label><span>Отправить мне</span><input asp-for="Settings.Post.DeveloperEmail" type="email" /></label>
                        <label><span>Контактный телефон</span><input asp-for="Settings.Post.ContactPhone" /></label>
                        <label class="check-field"><span>Use SSL</span><input asp-for="Settings.Post.UseSSL" type="checkbox" /></label>
                        <label><span>Send Limit</span><input asp-for="Settings.SendLimit" type="number" min="1" /></label>
                    </div>
                </details>
            </div>
            <button type="submit" class="btn btn-wave">Сохранить настройки</button>
        </form>
    </section>

    <section id="reportTab" class="panel newsmaker-tab">
        <div class="panel-title">
            <div><span class="step-number">Отчёт</span><h2>Ход выполнения</h2></div>
            <span class="muted">@Model.SubscriberCount подписчиков</span>
        </div>
        @if (Model.DatabaseError is not null) { <div class="alert alert-warning">@Model.DatabaseError</div> }
        <textarea class="report-memo" readonly>@string.Join(Environment.NewLine, Model.Run.Report)</textarea>
        <div class="newsmaker-progress"><div style="width:@percent%"></div></div>
        <div class="progress-caption">@Model.Run.Current / @Model.Run.Total</div>
        <div class="newsmaker-actions">
            @if (Model.Run.Running)
            {
                <form method="post" asp-page-handler="Stop"><button class="btn btn-danger" id="runButton">Остановить</button></form>
            }
            else
            {
                <form method="post" asp-page-handler="Start"><button class="btn btn-wave" id="runButton">Начать рассылку</button></form>
            }
            <form method="post" asp-page-handler="SendToMe"><button class="btn btn-outline-secondary" disabled="@Model.Run.Running">Отправить мне</button></form>
        </div>
    </section>
</div>

@section Scripts {
<script>
window.NewsWave.enhancePage(() => {
    $("#mainTabs").dxTabs({
        items: [{ text: "Установки", icon: "preferences" }, { text: "Отчёт", icon: "chart" }],
        selectedIndex: @(Model.Run.Running || Model.Run.Report.Count > 0 ? 1 : 0),
        onSelectionChanged: e => {
            const index = e.component.option("selectedIndex");
            $("#settingsTab").toggle(index === 0);
            $("#reportTab").toggle(index === 1);
        }
    });
    const start = @(Model.Run.Running || Model.Run.Report.Count > 0 ? 1 : 0);
    $("#settingsTab").toggle(start === 0);
    $("#reportTab").toggle(start === 1);
});
@if (Model.Run.Running) { <text>setTimeout(() => location.reload(), 2000);</text> }
</script>
}
